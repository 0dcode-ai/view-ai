generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Company {
  id                Int                @id @default(autoincrement())
  name              String             @unique
  aliasesJson       String             @default("[]")
  note              String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  interviewSessions InterviewSession[]
  experienceReports  ExperienceReport[]
  jobTargets        JobTarget[]
  knowledgeCards    KnowledgeCard[]
  sprintPlans       SprintPlan[]
}

model Topic {
  id             Int             @id @default(autoincrement())
  name           String          @unique
  description    String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  knowledgeCards KnowledgeCard[]
}

model KnowledgeCard {
  id            Int          @id @default(autoincrement())
  question      String
  answer        String
  companyId     Int?
  topicId       Int?
  roleDirection String?
  questionType  String       @default("technical")
  abilityDimension String    @default("基础知识")
  mastery       Int          @default(0)
  reviewCount   Int          @default(0)
  mistakeCount  Int          @default(0)
  lastReviewedAt DateTime?
  nextReviewAt  DateTime?
  priorityScore Int          @default(50)
  tagsJson      String       @default("[]")
  difficulty    String       @default("medium")
  source        String?
  note          String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  company       Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  reviewCards   ReviewCard[]
  topic         Topic?       @relation(fields: [topicId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([topicId])
  @@index([difficulty])
  @@index([mastery])
  @@index([questionType])
  @@index([priorityScore])
}

model ResumeProfile {
  id                    Int                @id @default(autoincrement())
  title                 String             @default("我的简历")
  rawText               String
  parsedJson            String             @default("{}")
  followUpQuestionsJson String             @default("[]")
  candidatePrepJson     String             @default("{}")
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  interviewSessions     InterviewSession[]
  jobTargets            JobTarget[]
  sprintPlans           SprintPlan[]
}

model JobTarget {
  id                Int                @id @default(autoincrement())
  companyId         Int?
  resumeProfileId   Int?
  roleName          String
  rawJd             String
  parsedJson        String             @default("{}")
  matchJson         String             @default("{}")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  company           Company?           @relation(fields: [companyId], references: [id], onDelete: SetNull)
  resumeProfile     ResumeProfile?     @relation(fields: [resumeProfileId], references: [id], onDelete: SetNull)
  interviewSessions InterviewSession[]
  sprintPlans       SprintPlan[]

  @@index([companyId])
  @@index([resumeProfileId])
}

model InterviewSession {
  id              Int             @id @default(autoincrement())
  mode            String
  roundType       String          @default("first_round")
  deliveryMode    String          @default("text")
  targetRole      String?
  targetCompanyId Int?
  resumeProfileId Int?
  jobTargetId     Int?
  status          String          @default("active")
  summary         String?
  scoreJson       String          @default("{}")
  expressionJson  String          @default("{}")
  contextJson     String          @default("{}")
  configJson      String          @default("{}")
  planJson        String          @default("{}")
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  company         Company?        @relation(fields: [targetCompanyId], references: [id], onDelete: SetNull)
  jobTarget       JobTarget?      @relation(fields: [jobTargetId], references: [id], onDelete: SetNull)
  resumeProfile   ResumeProfile?  @relation(fields: [resumeProfileId], references: [id], onDelete: SetNull)
  reviewCards     ReviewCard[]
  turns           InterviewTurn[]

  @@index([mode])
  @@index([roundType])
  @@index([status])
  @@index([jobTargetId])
}

model InterviewTurn {
  id                Int              @id @default(autoincrement())
  sessionId         Int
  order             Int
  question          String
  questionSource    String?
  turnType          String?
  parentTurnId      Int?
  intent            String?
  answer            String?
  feedback          String?
  betterAnswer      String?
  idealAnswer       String?
  transcriptSource  String           @default("text")
  answerDurationSec Int?
  audioMetaJson     String           @default("{}")
  expressionJson    String           @default("{}")
  scoreJson         String           @default("{}")
  reviewJson        String           @default("{}")
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  session           InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, order])
  @@index([sessionId])
}

model ReviewCard {
  id              Int               @id @default(autoincrement())
  sessionId       Int?
  knowledgeCardId Int?
  title           String
  weakness        String
  suggestion      String
  status          String            @default("todo")
  priority        Int               @default(50)
  dueAt           DateTime?
  tagsJson        String            @default("[]")
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  knowledgeCard   KnowledgeCard?    @relation(fields: [knowledgeCardId], references: [id], onDelete: SetNull)
  session         InterviewSession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([sessionId])
  @@index([priority])
}

model SprintPlan {
  id              Int          @id @default(autoincrement())
  companyId       Int?
  jobTargetId     Int?
  resumeProfileId Int?
  title           String
  targetRole      String?
  interviewDate   DateTime?
  days            Int          @default(7)
  status          String       @default("active")
  summary         String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  company         Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  jobTarget       JobTarget?   @relation(fields: [jobTargetId], references: [id], onDelete: SetNull)
  resumeProfile   ResumeProfile? @relation(fields: [resumeProfileId], references: [id], onDelete: SetNull)
  tasks           SprintTask[]

  @@index([companyId])
  @@index([jobTargetId])
  @@index([status])
}

model SprintTask {
  id          Int        @id @default(autoincrement())
  planId      Int
  dayIndex    Int
  type        String
  title       String
  description String
  status      String     @default("todo")
  dueDate     DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  plan        SprintPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([planId])
  @@index([status])
  @@index([dayIndex])
}

model LabSession {
  id            Int      @id @default(autoincrement())
  type          String
  roleDirection String?
  title         String
  prompt        String
  starterCode   String?
  content       String?
  feedbackJson  String   @default("{}")
  status        String   @default("active")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([type])
  @@index([status])
}

model ExperienceReport {
  id              Int               @id @default(autoincrement())
  companyId       Int?
  roleName        String
  level           String?
  location        String?
  interviewDate   DateTime?
  result          String            @default("unknown")
  difficulty      String            @default("medium")
  sourceType      String            @default("self")
  confidence      String            @default("medium")
  verified        Boolean           @default(false)
  durationMinutes Int?
  rawText         String
  summary         String?
  tagsJson        String            @default("[]")
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  company         Company?          @relation(fields: [companyId], references: [id], onDelete: SetNull)
  rounds          ExperienceRound[]

  @@index([companyId])
  @@index([roleName])
  @@index([interviewDate])
  @@index([verified])
  @@index([confidence])
}

model ExperienceRound {
  id               Int              @id @default(autoincrement())
  reportId         Int
  order            Int
  roundType        String
  durationMinutes  Int?
  interviewerStyle String?
  focusAreasJson   String           @default("[]")
  questionsJson    String           @default("[]")
  notes            String?
  report           ExperienceReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([roundType])
}

model TechnicalArticle {
  id          Int                     @id @default(autoincrement())
  title       String
  topic       String?
  tagsJson    String                  @default("[]")
  contentHtml String                  @default("")
  contentText String                  @default("")
  sourceUrl   String?
  summary     String?
  status      String                  @default("draft")
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  assets      TechnicalArticleAsset[]

  @@index([topic])
  @@index([status])
  @@index([updatedAt])
}

model TechnicalArticleAsset {
  id        Int               @id @default(autoincrement())
  articleId Int?
  url       String
  filePath  String
  mimeType  String
  size      Int
  width     Int?
  height    Int?
  altText   String?
  createdAt DateTime          @default(now())
  article   TechnicalArticle? @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId])
  @@index([mimeType])
}

model StartupIdea {
  id             Int      @id @default(autoincrement())
  title          String
  oneLiner       String   @default("")
  problem        String   @default("")
  targetUsers    String   @default("")
  solution       String   @default("")
  aiAgentFlow    String   @default("")
  dataSignals    String   @default("")
  monetization   String   @default("")
  validationPlan String   @default("")
  risks          String   @default("")
  tagsJson       String   @default("[]")
  status         String   @default("idea")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status])
  @@index([updatedAt])
}

model GithubRepository {
  id              Int                        @id @default(autoincrement())
  githubId        Int                        @unique
  fullName        String                     @unique
  owner           String
  name            String
  description     String?
  htmlUrl         String
  cloneUrl        String?
  homepage        String?
  language        String?
  topicsJson      String                     @default("[]")
  license         String?
  stars           Int                        @default(0)
  forks           Int                        @default(0)
  watchers        Int                        @default(0)
  openIssues      Int                        @default(0)
  defaultBranch   String?
  pushedAt        DateTime?
  createdAtGithub DateTime?
  updatedAtGithub DateTime?
  archived        Boolean                    @default(false)
  disabled        Boolean                    @default(false)
  isFork          Boolean                    @default(false)
  isFavorite      Boolean                    @default(false)
  note            String                     @default("")
  analysisJson    String                     @default("{}")
  lastAnalyzedAt  DateTime?
  firstSeenAt     DateTime                   @default(now())
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt
  snapshots       GithubRepositorySnapshot[]

  @@index([fullName])
  @@index([language])
  @@index([isFavorite])
  @@index([pushedAt])
  @@index([stars])
}

model GithubRepositorySnapshot {
  id           Int              @id @default(autoincrement())
  repositoryId Int
  snapshotDate String
  rank         Int              @default(0)
  score        Int              @default(0)
  stars        Int              @default(0)
  forks        Int              @default(0)
  openIssues   Int              @default(0)
  pushedAt     DateTime?
  query        String?
  topic        String?
  window       String?
  createdAt    DateTime         @default(now())
  repository   GithubRepository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@unique([repositoryId, snapshotDate])
  @@index([snapshotDate])
  @@index([score])
  @@index([repositoryId])
}
