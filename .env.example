DATABASE_URL="file:./dev.db"

# Leave OPENAI_API_KEY empty in the template. The app uses OpenAI-compatible chat completions.
AI_PROVIDER="openai"
OPENAI_BASE_URL="https://open.bigmodel.cn/api/coding/paas/v4"
OPENAI_API_KEY=""
OPENAI_MODEL="GLM-5.1"

# Optional. Used by the GitHub trends page to raise GitHub API limits.
GITHUB_TOKEN=""

# Optional. When set, the Web app calls the production Nest API for migrated resources.
# Example: NEXT_PUBLIC_API_BASE_URL="http://localhost:4000/v1"
NEXT_PUBLIC_API_BASE_URL=""
# Comma-separated migration whitelist. Keep this narrow while modules move to apps/api.
NEXT_PUBLIC_API_MIGRATED_RESOURCES="knowledge,resumes,job-targets,interviews,interviewer-sessions,reviews,sprints,daily,experiences,companies,labs,learning-paths,applications,resume-versions,sources,agents"

# New separated API (apps/api)
# Use a Supabase/Postgres connection string when running apps/api.
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
AUTH_DISABLED="true"
DEV_USER_ID="dev-user"
DEV_USER_EMAIL="dev@example.com"
BOOTSTRAP_USER_EMAIL="dev@example.com"
PORT="4000"
CORS_ORIGIN="http://localhost:3000"

# Expo mobile (apps/mobile)
EXPO_PUBLIC_API_BASE_URL="http://localhost:4000/v1"
EXPO_PUBLIC_SUPABASE_URL=""
EXPO_PUBLIC_SUPABASE_ANON_KEY=""
