{
  "expo": {
    "name": "Interview AI",
    "slug": "interview-ai-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "interviewai",
    "assetBundlePatterns": ["**/*"],
